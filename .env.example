# =============================================================================
# Geo-Location Based Attendance System — Environment Variables
#
# Copy this file to .env and fill in all values before starting services.
#   cp .env.example .env
#
# NEVER commit your actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=GeoAttendance
DEBUG=true
API_V1_PREFIX=/api/v1

# -----------------------------------------------------------------------------
# PostgreSQL
# Used by docker-compose to initialise the database container, and by the
# application / Alembic to connect.
# -----------------------------------------------------------------------------
POSTGRES_DB=attendance
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Async URL for the FastAPI application (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/attendance

# Synchronous URL used by Alembic and Celery workers (psycopg2 driver)
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:password@db:5432/attendance

# -----------------------------------------------------------------------------
# Redis
# DB 0 – general cache / sessions / pub-sub
# DB 1 – Celery broker
# DB 2 – Celery result backend
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------------------------------------------------------
# JWT / Authentication
# For production, switch JWT_ALGORITHM to RS256 and provide PEM-encoded keys.
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
# JWT_PRIVATE_KEY=       # PEM string or absolute path to private key file (RS256)
# JWT_PUBLIC_KEY=        # PEM string or absolute path to public key file (RS256)
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=attendance
MINIO_SECURE=false

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------
# IPQualityScore — fraud / VPN / proxy detection
IPQS_API_KEY=your_ipqs_api_key_here

# Firebase Cloud Messaging — push notifications
FCM_CREDENTIALS_PATH=/app/firebase-credentials.json

# Mapbox — map tiles / geocoding
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# -----------------------------------------------------------------------------
# CORS
# Comma-separated list of allowed origins for the FastAPI CORS middleware.
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

# -----------------------------------------------------------------------------
# Fraud / Geofencing defaults
# -----------------------------------------------------------------------------
DEFAULT_GEOFENCE_RADIUS_METERS=100
FRAUD_SCORE_THRESHOLD=0.75
